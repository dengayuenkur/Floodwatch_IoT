# ============================================================
#  Flood Monitoring System — Environment Configuration
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to version control.
# ============================================================

# ── Flask ──────────────────────────────────────────────────────────────────
FLASK_ENV=development
# Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme_generate_your_own_secret_key

# ── Database ───────────────────────────────────────────────────────────────
# SQLite (default — fine for development and small deployments)
DATABASE_URL=sqlite:///flood_monitor.db
# MySQL example:
# DATABASE_URL=mysql+pymysql://flooduser:password@localhost/flood_db
# PostgreSQL example:
# DATABASE_URL=postgresql://flooduser:password@localhost/flood_db

# ── JWT ─────────────────────────────────────────────────────────────────────
# Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=changeme_generate_your_own_jwt_secret_key

# ── Sensor API Key (copy this value into flood_sensor.ino) ─────────────────
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(32))"
SENSOR_API_KEY=changeme_generate_your_own_sensor_api_key

# ── Alert Thresholds (distance from sensor in cm) ──────────────────────────
SAFE_THRESHOLD=200
WARNING_THRESHOLD=100
DANGER_THRESHOLD=50

# ── Alert Cooldown ─────────────────────────────────────────────────────────
# Minimum seconds between repeated alerts for the same sensor
ALERT_COOLDOWN_SECONDS=300

# ── SMS Alerts via Twilio (leave blank to disable) ─────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
# Comma-separated list of recipient phone numbers (international format)
ALERT_PHONE_NUMBERS=+211912345678,+211923456789

# ── Email Alerts via Resend HTTP API (leave blank to disable) ─────────────
# SMTP ports are blocked outbound on most PaaS free tiers (Render included),
# so email alerts go through Resend's HTTPS API instead.
# Sign up free at https://resend.com and create an API key.
RESEND_API_KEY=changeme_generate_your_own_resend_api_key
# Sandbox sender works without domain verification, but can only send to
# the email address you signed up to Resend with until you verify your
# own domain in the Resend dashboard.
RESEND_FROM_EMAIL=onboarding@resend.dev
# Comma-separated list of recipient email addresses
ALERT_EMAILS=authority@juba.gov.ss,emergency@floods.ss

# ── MQTT (leave MQTT_ENABLED=false to use HTTP-only mode) ──────────────────
MQTT_ENABLED=false
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_TOPIC=flood/sensors/#
MQTT_USERNAME=
MQTT_PASSWORD=

# ── Logging ────────────────────────────────────────────────────────────────
LOG_FILE=logs/flood_monitor.log
LOG_LEVEL=INFO

# ── CORS ───────────────────────────────────────────────────────────────────
# In production, replace * with the exact dashboard domain
CORS_ORIGINS=*

# ── Data retention ─────────────────────────────────────────────────────────
DATA_RETENTION_DAYS=90
